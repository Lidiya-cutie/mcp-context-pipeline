# Proxy Configuration (для обхода региональных ограничений LLM API)
# Примеры:
# HTTP_PROXY=http://username:password@proxy.example.com:8080
# HTTP_PROXY=socks5://127.0.0.1:1080
# HTTP_PROXY=http://localhost:7890
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=

# VLESS Configuration (Hiddify, V2Ray и др.)
# Используйте run_vless.sh для автоматической настройки

# Прямая VLESS ссылка (альтернатива подписке)
# Пример: vless://uuid@host:port?type=ws&security=tls&host=domain.com&path=/path#remark
VLESS_URL=

# URL подписки Hiddify или V2Ray
# Пример: https://hiddify.com/s/subscription_code
VLESS_SUBSCRIPTION=

# Индекс сервера в подписке (0 = первый, 1 = второй, и т.д.)
VLESS_SERVER_INDEX=0

# Порты для локального прокси Xray
XRAY_SOCKS_PORT=10809
XRAY_HTTP_PORT=10808

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Redis Connection URL
REDIS_URL=redis://localhost:6379

# PostgreSQL Connection URL (port 5433 to avoid conflicts)
POSTGRES_URL=postgresql://mcp_user:mcp_password@localhost:5433/mcp_memory

# Context Settings
MAX_TOKENS=128000
SUMMARY_THRESHOLD=100000

# Context7 API Key (опционально, для повышенных лимитов)
# Получите бесплатный API ключ на https://context7.com/dashboard
CONTEXT7_API_KEY=your-context7-api-key-here

# External Knowledge Router
EXTERNAL_KNOWLEDGE_CACHE_TTL=3600
ENABLE_GITHUB_PROVIDER=false
EXTERNAL_KNOWLEDGE_USE_REDIS=true
EXTERNAL_KNOWLEDGE_REDIS_PREFIX=extk
# Optional JSON, e.g. {"github":1.0,"context7":0.98,"tavily":0.78}
EXTERNAL_KNOWLEDGE_SOURCE_WEIGHTS=
EXTERNAL_METRICS_HISTORY_MAXLEN=5000
EXTERNAL_METRICS_HISTORY_TTL_SECONDS=604800
EXTERNAL_ALERT_HIT_RATE_MIN=0.30
EXTERNAL_ALERT_P95_MAX_MS=5000
EXTERNAL_ALERT_MIN_REQUESTS=20
EXTERNAL_PROVIDER_HEALTH_TTL_SECONDS=604800
EXTERNAL_MASK_PII_QUERIES=true

# Local Index Provider (SQLite FTS5)
ENABLE_LOCAL_INDEX_PROVIDER=true
EXTERNAL_LOCAL_INDEX_DB_PATH=/mldata/mcp_context_pipeline/data/external_knowledge_index.db
# Optional bootstrap folder with local knowledge docs/code
EXTERNAL_LOCAL_INDEX_BOOTSTRAP_DIR=

# Tavily Provider
ENABLE_TAVILY_PROVIDER=true
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search

# Exa Provider
ENABLE_EXA_PROVIDER=true
EXA_API_KEY=
EXA_API_URL=https://api.exa.ai/search

# Firecrawl Provider
ENABLE_FIRECRAWL_PROVIDER=true
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev/v1/search

# SHIVA MCP Provider
ENABLE_SHIVA_PROVIDER=false
SHIVA_MCP_URL=https://shiva.imbalanced.tech/shiva-mcp/v0
SHIVA_MCP_TOKEN=
SHIVA_DEFAULT_PROJECT_ID=

# DocFusion Provider
ENABLE_DOCFUSION_PROVIDER=false
# If empty, SHIVA_MCP_TOKEN will be used
DOCFUSION_TOKEN=
# Comma-separated URLs
DOCFUSION_KB_URLS=https://docfusion.imbalanced.tech/kb/frontend/1250af63-bdf9-42b1-8d2a-40d0e2d94d35,https://docfusion.imbalanced.tech/folder/18a9d63c-2305-4999-bf9a-9573565fc576/kb,https://docops-prod.imbalanced.tech/#/guide/Regulations-and-agreements/594?documentName=Document+Catalog.md&path=Document+Catalog.md&branch=main&type=text/markdown&webUrl=https://git.imbalanced.tech/government/agreements-policies-regulations/-/blob/main/Document%2520Catalog.md?ref_type=heads

# Live external-provider tests
LIVE_EXTERNAL_TEST_STRICT=false
LIVE_EXTERNAL_TEST_QUERY=fastapi jwt authentication middleware

# Stage 4 Offline Evaluation
EVAL_DATASET_PATH=/mldata/mcp_context_pipeline/eval_queries_v3.jsonl
EVAL_OUTPUT_DIR=/mldata/mcp_context_pipeline/artifacts/external_knowledge_eval
EVAL_TOP_K=5
EVAL_RECORD_LIMIT=
EVAL_CACHE_WARM_REPEAT=1
EVAL_DEGRADATION_SAMPLE_SIZE=50
EVAL_MIN_RECALL_AT_K=0.60
EVAL_MIN_MRR=0.45
EVAL_MIN_SOURCE_COVERAGE=0.95
EVAL_MIN_PROVENANCE_COVERAGE=0.95
EVAL_MAX_NOT_FOUND_RATE=0.20
EVAL_MAX_P95_MS=8000
EVAL_MIN_CACHE_HIT_RATE=0.20
EVAL_MIN_FALLBACK_SUCCESS_RATE=0.95

# REST API Quality Evaluation
REST_API_EVAL_DATASET=/mldata/mcp_context_pipeline/data/rest_api_eval_good.jsonl
REST_API_EVAL_OUTPUT=/mldata/mcp_context_pipeline/artifacts/rest_api_eval
REST_API_EVAL_RECORD_LIMIT=
REST_API_MIN_RESOURCE_ORIENTATION=0.8
REST_API_MIN_PAGINATION=0.7
REST_API_MIN_VERSIONING=0.6
REST_API_MIN_ERROR_CODES=0.7
REST_API_MIN_STRUCTURAL_REDUNDANCY=0.6
REST_API_MIN_OVERALL_SCORE=0.7
