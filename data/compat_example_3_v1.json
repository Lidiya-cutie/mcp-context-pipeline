{
  "openapi": "3.0.0",
  "info": {
    "title": "Comments API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/comments": {
      "get": {
        "summary": "List comments",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "integer"},
                          "content": {"type": "string"},
                          "author_id": {"type": "integer"},
                          "status": {"type": "string"}
                        },
                        "required": ["id", "content"]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create comment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": {"type": "string"},
                  "author_id": {"type": "integer"},
                  "status": {"type": "string"}
                },
                "required": ["content", "author_id"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "content": {"type": "string"},
                    "author_id": {"type": "integer"},
                    "status": {"type": "string"}
                  },
                  "required": ["id", "content"]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Comment": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "content": {"type": "string"},
          "author_id": {"type": "integer"},
          "status": {"type": "string"}
        },
        "required": ["id", "content"]
      }
    }
  }
}
