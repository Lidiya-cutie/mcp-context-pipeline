{
  "openapi": "3.0.0",
  "info": {
    "title": "Notifications API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/notifications": {
      "get": {
        "summary": "List notifications",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "integer"},
                          "message": {"type": "string"},
                          "read": {"type": "boolean"}
                        },
                        "required": ["id", "message"]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create notification",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {"type": "string"},
                  "user_id": {"type": "integer"}
                },
                "required": ["message", "user_id"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "message": {"type": "string"},
                    "read": {"type": "boolean"}
                  },
                  "required": ["id", "message"]
                }
              }
            }
          }
        }
      }
    },
    "/api/notifications/{id}": {
      "get": {
        "summary": "Get notification",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "message": {"type": "string"},
                    "read": {"type": "boolean"}
                  },
                  "required": ["id", "message"]
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Mark notification as read",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "read": {"type": "boolean"}
                },
                "required": ["read"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "message": {"type": "string"},
                    "read": {"type": "boolean"}
                  },
                  "required": ["id", "message"]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Notification": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "message": {"type": "string"},
          "read": {"type": "boolean"}
        },
        "required": ["id", "message"]
      }
    }
  }
}
